theorem numberedDirectRouteWrappersKeepCurrentSurfaceW1282 :
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      branchFullDataNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      currentFullDataNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      branchFullDataReturnAliasInputNamesW1282.length := by
  rw [currentFullDataPayloadFromBranchFullDataInputNamesW1270_count,
    branchFullDataNumberedAliasInputNamesW1282_count,
    currentFullDataNumberedAliasInputNamesW1282_count,
    branchFullDataReturnAliasInputNamesW1282_count]
  exact ⟨rfl, rfl, rfl⟩

theorem numberedDirectRouteAliasesDoNotReduceW1282 :
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      componentFieldsNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      unitStrictExactIsoDataNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      localizedUnitChoiceNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      endpointLocalizedUnitNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      normalizedSourceEndpointLocalizedUnitNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      targetClosedEmbeddingClosednessNumberedAliasInputNamesW1282.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      targetClosedEmbeddingClosednessNormalizedSourceEndpointNumberedAliasInputNamesW1282.length := by
  rw [currentFullDataPayloadFromBranchFullDataInputNamesW1270_count,
    componentFieldsNumberedAliasInputNamesW1282_count,
    unitStrictExactIsoDataNumberedAliasInputNamesW1282_count,
    localizedUnitChoiceNumberedAliasInputNamesW1282_count,
    endpointLocalizedUnitNumberedAliasInputNamesW1282_count,
    normalizedSourceEndpointLocalizedUnitNumberedAliasInputNamesW1282_count,
    targetClosedEmbeddingClosednessNumberedAliasInputNamesW1282_count,
    targetClosedEmbeddingClosednessNormalizedSourceEndpointNumberedAliasInputNamesW1282_count]
  norm_num

