theorem olderChainExpansionsDoNotReduceW1280 :
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      noUnivLocalizedUnitChoiceInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      noUnivUnitStrictExactIsoInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      componentFieldsInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      unitStrictExactIsoDataInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      localizedUnitChoiceInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      endpointLocalizedUnitInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      normalizedSourceEndpointLocalizedUnitInputNamesW1280.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length <
      targetClosedEmbeddingClosednessInputNamesW1280.length := by
  rw [currentFullDataPayloadFromBranchFullDataInputNamesW1270_count,
    noUnivLocalizedUnitChoiceInputNamesW1280_count,
    noUnivUnitStrictExactIsoInputNamesW1280_count,
    componentFieldsInputNamesW1280_count,
    unitStrictExactIsoDataInputNamesW1280_count,
    localizedUnitChoiceInputNamesW1280_count,
    endpointLocalizedUnitInputNamesW1280_count,
    normalizedSourceEndpointLocalizedUnitInputNamesW1280_count,
    targetClosedEmbeddingClosednessInputNamesW1280_count]
  norm_num

