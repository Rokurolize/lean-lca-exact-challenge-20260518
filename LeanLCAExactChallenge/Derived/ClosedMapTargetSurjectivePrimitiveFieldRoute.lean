/-- W923 primitive form of the target-difference surjectivity field. -/
abbrev targetDifferenceSurjectivePrimitiveW923
    (Y : WalkingParallelPairᵒᵖ ⥤ MetrizableLCA.{0}) : Prop :=
  ∀ y : wppOpCodomainW441 Y,
    ∃ x : wppOpDomainW441 Y,
      (((wppOpLeftW441 Y - wppOpRightW441 Y) :
        wppOpDomainW441 Y ⟶ wppOpCodomainW441 Y) :
        wppOpDomainW441 Y → wppOpCodomainW441 Y) x = y

/-- W923 assembles the target-difference surjectivity field. -/
abbrev targetDifferenceSurjectiveOfPrimitiveW923
    (targetDifferenceSurjectiveForTargetProvider :
      ∀ Y : WalkingParallelPairᵒᵖ ⥤ MetrizableLCA.{0},
        targetDifferenceSurjectivePrimitiveW923 Y) :
    ∀ (Y : WalkingParallelPairᵒᵖ ⥤ MetrizableLCA.{0}),
      Function.Surjective
        (((wppOpLeftW441 Y - wppOpRightW441 Y) :
          wppOpDomainW441 Y ⟶ wppOpCodomainW441 Y) :
          wppOpDomainW441 Y → wppOpCodomainW441 Y) := by
  intro Y
  simpa [targetDifferenceSurjectivePrimitiveW923, Function.Surjective] using
    targetDifferenceSurjectiveForTargetProvider Y

