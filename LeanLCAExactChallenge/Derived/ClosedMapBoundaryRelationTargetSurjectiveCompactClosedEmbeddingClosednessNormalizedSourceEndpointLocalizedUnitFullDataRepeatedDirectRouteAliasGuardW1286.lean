theorem repeatedDirectRouteWrappersKeepCurrentSurfaceW1286 :
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      currentFullDataInputNamesW1089.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      branchFullDataInputNamesW1097.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      currentFullDataInputNamesW1098.length ∧
    currentFullDataPayloadFromBranchFullDataInputNamesW1270.length =
      branchFullDataInputNamesW1106.length := by
  rw [currentFullDataPayloadFromBranchFullDataInputNamesW1270_count,
    currentFullDataInputNamesW1089_count,
    branchFullDataInputNamesW1097_count,
    currentFullDataInputNamesW1098_count,
    branchFullDataInputNamesW1106_count]
  exact ⟨rfl, rfl, rfl, rfl⟩

